# ============================================
# Frontend .gitignore - Node.js/React/Vite
# ============================================

# Dependencies (installed via npm ci)
node_modules/

# Build output (generated by npm run build)
dist/
build/

# IDE-specific files
.idea/
.vscode/
*.swp
*.swo
*~

# OS-generated files
.DS_Store
Thumbs.db
desktop.ini

# Environment variables and secrets (never commit API keys)
.env
.env.local
.env.production.local
.env.development.local

# Log files
*.log
npm-debug.log*

# Terraform state files (contain sensitive infrastructure data)
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/*.tfvars
terraform/.terraform.lock.hcl

# Test coverage output
coverage/
